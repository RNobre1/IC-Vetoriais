# === PostgreSQL + pgvector ===
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=icvet
PG_USER=icvet
PG_PASSWORD=icvet

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# === Weaviate ===
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# === Pipeline / embeddings ===
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# === Datasets / artefatos (paths relativos a code/) ===
MS_MARCO_DIR=../data/ms_marco
EMBEDDINGS_DIR=../data/embeddings
GROUND_TRUTH_DIR=../data/ground_truth
RESULTS_DIR=./results

# datasets brutos — volume grande, não versionar
data/

# python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# locks de office (LibreOffice/Word)
.~lock.*#

# obsidian — workspace local do usuário, não compartilhar
vault/.obsidian/workspace*
vault/.obsidian/cache/
.trash/

# vault/papers — fichamentos .md versionados; PDFs/HTML/_files ignorados (volume + direitos autorais)
vault/papers/*.pdf
vault/papers/*.html
vault/papers/*_files/

# editores / SO
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# logs / artefatos de benchmark
*.log
results/
.xp-stack/state/
